  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#B8B8B8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment doc",
      "scope": [
        "comment.block.documentation"
      ],
      "settings": {
        "foreground": "#B8B8B8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable, parameter, property",
      "scope": [
        "variable",
        "support.variable",
        "meta.definition.variable",
        "variable.parameter",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#F9F8F2"
      }
    },
    {
      "name": "Variable language (this, self)",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#E8A8EE",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "storage"
      ],
      "settings": {
        "foreground": "#C6FF24"
      }
    },
    {
      "name": "Storage type modifier",
      "scope": [
        "storage.modifier",
        "storage.type.function",
        "keyword.operator.expression.typeof"
      ],
      "settings": {
        "foreground": "#C6FF24",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#E4E4E4"
      }
    },
    {
      "name": "String interpolation punctuation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#C6FF24"
      }
    },
    {
      "name": "String escape",
      "scope": [
        "constant.character.escape",
        "string.regexp",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#9DE5E5"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#FFC25A"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#E8A8EE"
      }
    },
    {
      "name": "Function name (the lime hero)",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function",
        "meta.definition.function entity.name.function"
      ],
      "settings": {
        "foreground": "#C6FF24"
      }
    },
    {
      "name": "Function call (slightly less hot)",
      "scope": [
        "meta.function-call.generic",
        "variable.function"
      ],
      "settings": {
        "foreground": "#C6FF24"
      }
    },
    {
      "name": "Class / type / interface",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.other.inherited-class",
        "support.type",
        "support.class",
        "meta.type"
      ],
      "settings": {
        "foreground": "#7FB7FF"
      }
    },
    {
      "name": "Operator / punctuation",
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#B8B8B8"
      }
    },
    {
      "name": "Decorator",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#E8A8EE",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup heading",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#C6FF24",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#7FB7FF",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markup bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#F9F8F2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#F9F8F2",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#9DE5E5"
      }
    },
    {
      "name": "Markup quote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#B8B8B8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup list",
      "scope": [
        "markup.list",
        "punctuation.definition.list_item"
      ],
      "settings": {
        "foreground": "#C6FF24"
      }
    },
    {
      "name": "Diff added",
      "scope": [
        "markup.inserted",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#5FD06F"
      }
    },
    {
      "name": "Diff removed",
      "scope": [
        "markup.deleted",
        "meta.diff.header.from-file"
      ],
      "settings": {
        "foreground": "#FF6B73"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#FFC25A"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#7FB7FF"
      }
    },
    {
      "name": "Tag attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#FFC25A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "JSX punctuation",
      "scope": [
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": {
        "foreground": "#B8B8B8"
      }
    },
    {
      "name": "CSS property",
      "scope": [
        "support.type.property-name.css",
        "support.type.vendored.property-name"
      ],
      "settings": {
        "foreground": "#F9F8F2"
      }
    },
    {
      "name": "CSS value",
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value.css"
      ],
      "settings": {
        "foreground": "#E4E4E4"
      }
    },
    {
      "name": "CSS units",
      "scope": [
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#9DE5E5"
      }
    },
    {
      "name": "CSS selector",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.name.tag.css"
      ],
      "settings": {
        "foreground": "#C6FF24"
      }
    },
    {
      "name": "CSS pseudo",
      "scope": [
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#E8A8EE",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF6B73",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Python self",
      "scope": [
        "variable.language.special.self.python"
      ],
      "settings": {
        "foreground": "#E8A8EE",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust lifetime",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#E8A8EE",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Go package",
      "scope": [
        "entity.name.package.go"
      ],
      "settings": {
        "foreground": "#7FB7FF"
      }
    },
    {
      "name": "Shell command",
      "scope": [
        "entity.name.command.shell",
        "support.function.builtin.shell"
      ],
      "settings": {
        "foreground": "#C6FF24"
      }
    },
    {
      "name": "Shell variable",
      "scope": [
        "variable.parameter.positional.shell",
        "variable.other.special.shell"
      ],
      "settings": {
        "foreground": "#E8A8EE"
      }
    },
    {
      "name": "JSON key",
      "scope": [
        "support.type.property-name.json",
        "meta.structure.dictionary.key.json"
      ],
      "settings": {
        "foreground": "#7FB7FF"
      }
    },
    {
      "name": "YAML key",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#7FB7FF"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#C6FF24",
    "function.declaration": "#C6FF24",
    "method": "#C6FF24",
    "method.declaration": "#C6FF24",
    "class": "#7FB7FF",
    "interface": "#7FB7FF",
    "type": "#7FB7FF",
    "typeParameter": {
      "foreground": "#7FB7FF",
      "fontStyle": "italic"
    },
    "enum": "#7FB7FF",
    "enumMember": "#E8A8EE",
    "namespace": "#7FB7FF",
    "parameter": "#F9F8F2",
    "variable": "#F9F8F2",
    "variable.constant": "#E8A8EE",
    "variable.readonly": "#E8A8EE",
    "property": "#F9F8F2",
    "property.declaration": "#F9F8F2",
    "property.readonly": "#E8A8EE",
    "macro": {
      "foreground": "#E8A8EE",
      "fontStyle": "italic"
    },
    "decorator": {
      "foreground": "#E8A8EE",
      "fontStyle": "italic"
    },
    "keyword": "#C6FF24"
  }
}