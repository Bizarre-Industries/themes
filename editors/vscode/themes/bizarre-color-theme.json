{
  "$schema": "vscode://schemas/color-theme",
  "name": "Bizarre",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#0E0E0E",
    "editor.foreground": "#E4E4E4",
    "editorLineNumber.foreground": "#3D3D3D",
    "editorLineNumber.activeForeground": "#C6FF24",
    "editorCursor.foreground": "#C6FF24",
    "editor.selectionBackground": "#2B3A0E",
    "editor.lineHighlightBackground": "#16190B",
    "editor.findMatchBackground": "#3F5512",
    "editor.findMatchHighlightBackground": "#2B3A0E",

    "editorGroupHeader.tabsBackground": "#0E0E0E",
    "tab.activeBackground": "#0E0E0E",
    "tab.activeForeground": "#C6FF24",
    "tab.inactiveBackground": "#1A1A1A",
    "tab.inactiveForeground": "#9C9C9C",
    "tab.activeBorderTop": "#C6FF24",
    "tab.border": "#1F1F1F",

    "activityBar.background": "#0E0E0E",
    "activityBar.foreground": "#E4E4E4",
    "activityBar.activeBorder": "#C6FF24",
    "activityBarBadge.background": "#C6FF24",
    "activityBarBadge.foreground": "#0E0E0E",

    "sideBar.background": "#1A1A1A",
    "sideBar.foreground": "#E4E4E4",
    "sideBarTitle.foreground": "#9C9C9C",
    "sideBarSectionHeader.background": "#1A1A1A",
    "sideBarSectionHeader.foreground": "#7A7A7A",

    "statusBar.background": "#1A1A1A",
    "statusBar.foreground": "#9C9C9C",
    "statusBar.debuggingBackground": "#C6FF24",
    "statusBar.debuggingForeground": "#0E0E0E",
    "statusBar.noFolderBackground": "#1A1A1A",
    "statusBarItem.remoteBackground": "#C6FF24",
    "statusBarItem.remoteForeground": "#0E0E0E",

    "titleBar.activeBackground": "#0E0E0E",
    "titleBar.activeForeground": "#E4E4E4",
    "titleBar.inactiveBackground": "#0E0E0E",
    "titleBar.inactiveForeground": "#7A7A7A",

    "panel.background": "#0E0E0E",
    "panel.border": "#1F1F1F",
    "panelTitle.activeForeground": "#C6FF24",
    "panelTitle.inactiveForeground": "#7A7A7A",

    "terminal.background": "#0E0E0E",
    "terminal.foreground": "#E4E4E4",
    "terminalCursor.foreground": "#C6FF24",
    "terminal.ansiBlack": "#0E0E0E", "terminal.ansiRed": "#F0525B",
    "terminal.ansiGreen": "#3FB950", "terminal.ansiYellow": "#E8A33D",
    "terminal.ansiBlue": "#5B9FFF", "terminal.ansiMagenta": "#D88AE0",
    "terminal.ansiCyan": "#7AD9D9", "terminal.ansiWhite": "#E4E4E4",
    "terminal.ansiBrightBlack": "#3D3D3D", "terminal.ansiBrightRed": "#FF6F77",
    "terminal.ansiBrightGreen": "#5BD06B", "terminal.ansiBrightYellow": "#FFB85C",
    "terminal.ansiBrightBlue": "#7BB3FF", "terminal.ansiBrightMagenta": "#E8A8EE",
    "terminal.ansiBrightCyan": "#9DEAEA", "terminal.ansiBrightWhite": "#FFFFFF",

    "gitDecoration.modifiedResourceForeground": "#E8A33D",
    "gitDecoration.untrackedResourceForeground": "#FFB85C",
    "gitDecoration.deletedResourceForeground": "#FF6F77",
    "gitDecoration.addedResourceForeground": "#5BD06B",
    "gitDecoration.conflictingResourceForeground": "#FF6F77",
    "gitDecoration.ignoredResourceForeground": "#545454",

    "editorError.foreground": "#FF6F77",
    "editorWarning.foreground": "#FFB85C",
    "editorInfo.foreground": "#7BB3FF",
    "editorHint.foreground": "#D88AE0"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#6F6F6F", "fontStyle": "italic" } },
    { "scope": ["comment.block.documentation", "comment.line.documentation"], "settings": { "foreground": "#9AB585", "fontStyle": "italic" } },
    { "scope": ["punctuation"], "settings": { "foreground": "#7A7A7A" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#9DEAEA" } },
    { "scope": ["keyword.control", "keyword.control.flow", "keyword.control.return", "keyword.control.import", "keyword.control.conditional", "keyword.control.loop"], "settings": { "foreground": "#FF8FCF" } },
    { "scope": ["keyword.declaration", "storage.type", "storage.type.function", "storage.type.class"], "settings": { "foreground": "#D88AE0", "fontStyle": "" } },
    { "scope": ["storage.modifier", "keyword.other.async", "keyword.other.static", "keyword.other.public"], "settings": { "foreground": "#B989E5", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted"], "settings": { "foreground": "#E8A33D" } },
    { "scope": ["string.template", "string.interpolated"], "settings": { "foreground": "#FFC36B" } },
    { "scope": ["constant.character.escape", "punctuation.section.embedded"], "settings": { "foreground": "#FFE08A", "fontStyle": "bold" } },
    { "scope": ["string.regexp"], "settings": { "foreground": "#FF9E3D", "fontStyle": "italic" } },
    { "scope": ["constant.numeric"], "settings": { "foreground": "#7BB3FF" } },
    { "scope": ["constant.language", "constant.language.boolean", "constant.language.null"], "settings": { "foreground": "#5B9FFF", "fontStyle": "bold" } },
    { "scope": ["constant.other", "variable.other.constant", "entity.name.constant"], "settings": { "foreground": "#9DD0FF", "fontStyle": "bold" } },
    { "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"], "settings": { "foreground": "#7AD9D9" } },
    { "scope": ["storage.type.primitive", "support.type.primitive", "support.type.builtin"], "settings": { "foreground": "#7AD9D9", "fontStyle": "italic" } },
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#C6FF24" } },
    { "scope": ["meta.function-call entity.name.function", "variable.function"], "settings": { "foreground": "#A8E658" } },
    { "scope": ["variable.other.property", "variable.other.object.property", "meta.property.object"], "settings": { "foreground": "#C6E58B" } },
    { "scope": ["variable.parameter", "meta.function.parameters variable"], "settings": { "foreground": "#FFB07A", "fontStyle": "italic" } },
    { "scope": ["variable.language.this", "variable.language.self"], "settings": { "foreground": "#FF8FCF", "fontStyle": "italic" } },
    { "scope": ["variable", "variable.other"], "settings": { "foreground": "#E4E4E4" } },
    { "scope": ["support.function.builtin", "support.variable"], "settings": { "foreground": "#E8A33D", "fontStyle": "" } },
    { "scope": ["entity.name.namespace", "entity.name.module", "support.module"], "settings": { "foreground": "#9DEAEA" } },
    { "scope": ["meta.decorator", "punctuation.decorator", "entity.name.function.decorator"], "settings": { "foreground": "#FF8FCF", "fontStyle": "italic" } },
    { "scope": ["meta.preprocessor", "keyword.other.preprocessor", "entity.name.function.preprocessor"], "settings": { "foreground": "#B989E5", "fontStyle": "" } },
    { "scope": ["entity.name.tag", "meta.tag"], "settings": { "foreground": "#FF8FCF" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#C6FF24" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#C6FF24", "fontStyle": "bold" } },
    { "scope": ["markup.bold"], "settings": { "fontStyle": "bold" } },
    { "scope": ["markup.italic"], "settings": { "fontStyle": "italic" } },
    { "scope": ["markup.inserted"], "settings": { "foreground": "#5BD06B" } },
    { "scope": ["markup.deleted"], "settings": { "foreground": "#FF6F77" } },
    { "scope": ["markup.changed"], "settings": { "foreground": "#FFB85C" } }
  ],
  "semanticTokenColors": {
    "parameter": { "foreground": "#FFB07A", "italic": true },
    "property": "#C6E58B",
    "function": "#C6FF24",
    "method": "#A8E658",
    "namespace": "#9DEAEA",
    "type": "#7AD9D9",
    "class": "#7AD9D9",
    "enum": "#7AD9D9",
    "enumMember": "#9DD0FF",
    "interface": { "foreground": "#7AD9D9", "italic": true },
    "macro": "#FF8FCF",
    "decorator": { "foreground": "#FF8FCF", "italic": true }
  }
}
