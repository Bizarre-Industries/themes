  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#6F6F6F",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Documentation",
      "scope": [
        "comment.block.documentation"
      ],
      "settings": {
        "foreground": "#9AB585",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "support.variable",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#E4E4E4"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#FFB07A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Properties",
      "scope": [
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#C6E58B"
      }
    },
    {
      "name": "Self",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#FF8FCF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords control",
      "scope": [
        "keyword.control",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#FF8FCF"
      }
    },
    {
      "name": "Keywords declaration",
      "scope": [
        "storage.type",
        "storage.modifier",
        "keyword.declaration"
      ],
      "settings": {
        "foreground": "#D88AE0"
      }
    },
    {
      "name": "Keywords modifier",
      "scope": [
        "storage.modifier.async",
        "storage.modifier.static"
      ],
      "settings": {
        "foreground": "#B989E5",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "punctuation.separator"
      ],
      "settings": {
        "foreground": "#9DEAEA"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#7A7A7A"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#E8A33D"
      }
    },
    {
      "name": "Templates",
      "scope": [
        "string.template",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#FFC36B"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#FFE08A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#FF9E3D",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#7BB3FF"
      }
    },
    {
      "name": "Booleans",
      "scope": [
        "constant.language.boolean",
        "constant.language.null"
      ],
      "settings": {
        "foreground": "#5B9FFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#9DD0FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "support.type",
        "entity.name.class",
        "entity.name.struct"
      ],
      "settings": {
        "foreground": "#7AD9D9"
      }
    },
    {
      "name": "Primitive types",
      "scope": [
        "support.type.primitive"
      ],
      "settings": {
        "foreground": "#7AD9D9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#C6FF24"
      }
    },
    {
      "name": "Methods",
      "scope": [
        "entity.name.function.member",
        "support.function.method"
      ],
      "settings": {
        "foreground": "#A8E658"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.constant",
        "support.class",
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#E8A33D"
      }
    },
    {
      "name": "Namespaces",
      "scope": [
        "entity.name.namespace",
        "support.module"
      ],
      "settings": {
        "foreground": "#9DEAEA"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#FF8FCF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Preprocessor",
      "scope": [
        "meta.preprocessor",
        "keyword.control.directive"
      ],
      "settings": {
        "foreground": "#B989E5"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#FF8FCF"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#C6FF24"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF6F77",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup heading",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#C6FF24",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup link",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#7BB3FF",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markup bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#E4E4E4",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#E4E4E4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#5BD06B"
      }
    },
    {
      "name": "Diff deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#FF6F77"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#FFB85C"
      }
    }
  ],
  "semanticTokenColors": {
    "variable": "#E4E4E4",
    "parameter": {
      "foreground": "#FFB07A",
      "italic": true
    },
    "property": "#C6E58B",
    "function": "#C6FF24",
    "method": "#A8E658",
    "class": "#7AD9D9",
    "struct": "#7AD9D9",
    "interface": "#7AD9D9",
    "enum": "#7AD9D9",
    "enumMember": "#9DD0FF",
    "type": "#7AD9D9",
    "typeParameter": {
      "foreground": "#7AD9D9",
      "italic": true
    },
    "namespace": "#9DEAEA",
    "keyword": "#FF8FCF",
    "string": "#E8A33D",
    "number": "#7BB3FF",
    "regexp": {
      "foreground": "#FF9E3D",
      "italic": true
    },
    "decorator": {
      "foreground": "#FF8FCF",
      "italic": true
    },
    "comment": {
      "foreground": "#6F6F6F",
      "italic": true
    }
  },
  "$schema": "vscode://schemas/color-theme"
}
