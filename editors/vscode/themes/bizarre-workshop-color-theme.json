  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#7A786F",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment doc",
      "scope": [
        "comment.block.documentation"
      ],
      "settings": {
        "foreground": "#7A786F",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable, parameter, property",
      "scope": [
        "variable",
        "support.variable",
        "meta.definition.variable",
        "variable.parameter",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#E4E2DA"
      }
    },
    {
      "name": "Variable language (this, self)",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#C68DD0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "storage"
      ],
      "settings": {
        "foreground": "#D4EE7A"
      }
    },
    {
      "name": "Storage type modifier",
      "scope": [
        "storage.modifier",
        "storage.type.function",
        "keyword.operator.expression.typeof"
      ],
      "settings": {
        "foreground": "#D4EE7A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#B8B6AE"
      }
    },
    {
      "name": "String interpolation punctuation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#D4EE7A"
      }
    },
    {
      "name": "String escape",
      "scope": [
        "constant.character.escape",
        "string.regexp",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#7BC9C9"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#E8A33D"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#C68DD0"
      }
    },
    {
      "name": "Function name (the lime hero)",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function",
        "meta.definition.function entity.name.function"
      ],
      "settings": {
        "foreground": "#B5E81F"
      }
    },
    {
      "name": "Function call (slightly less hot)",
      "scope": [
        "meta.function-call.generic",
        "variable.function"
      ],
      "settings": {
        "foreground": "#B5E81F"
      }
    },
    {
      "name": "Class / type / interface",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.other.inherited-class",
        "support.type",
        "support.class",
        "meta.type"
      ],
      "settings": {
        "foreground": "#6EA8E8"
      }
    },
    {
      "name": "Operator / punctuation",
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#7A786F"
      }
    },
    {
      "name": "Decorator",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#C68DD0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup heading",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#B5E81F",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#6EA8E8",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markup bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#E4E2DA",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#E4E2DA",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#7BC9C9"
      }
    },
    {
      "name": "Markup quote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#7A786F",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup list",
      "scope": [
        "markup.list",
        "punctuation.definition.list_item"
      ],
      "settings": {
        "foreground": "#D4EE7A"
      }
    },
    {
      "name": "Diff added",
      "scope": [
        "markup.inserted",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#4CB058"
      }
    },
    {
      "name": "Diff removed",
      "scope": [
        "markup.deleted",
        "meta.diff.header.from-file"
      ],
      "settings": {
        "foreground": "#E8525B"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#D89538"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#6EA8E8"
      }
    },
    {
      "name": "Tag attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#E8A33D",
        "fontStyle": "italic"
      }
    },
    {
      "name": "JSX punctuation",
      "scope": [
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": {
        "foreground": "#7A786F"
      }
    },
    {
      "name": "CSS property",
      "scope": [
        "support.type.property-name.css",
        "support.type.vendored.property-name"
      ],
      "settings": {
        "foreground": "#E4E2DA"
      }
    },
    {
      "name": "CSS value",
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value.css"
      ],
      "settings": {
        "foreground": "#B8B6AE"
      }
    },
    {
      "name": "CSS units",
      "scope": [
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#7BC9C9"
      }
    },
    {
      "name": "CSS selector",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.name.tag.css"
      ],
      "settings": {
        "foreground": "#B5E81F"
      }
    },
    {
      "name": "CSS pseudo",
      "scope": [
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#C68DD0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#E8525B",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Python self",
      "scope": [
        "variable.language.special.self.python"
      ],
      "settings": {
        "foreground": "#C68DD0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust lifetime",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#C68DD0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Go package",
      "scope": [
        "entity.name.package.go"
      ],
      "settings": {
        "foreground": "#6EA8E8"
      }
    },
    {
      "name": "Shell command",
      "scope": [
        "entity.name.command.shell",
        "support.function.builtin.shell"
      ],
      "settings": {
        "foreground": "#B5E81F"
      }
    },
    {
      "name": "Shell variable",
      "scope": [
        "variable.parameter.positional.shell",
        "variable.other.special.shell"
      ],
      "settings": {
        "foreground": "#C68DD0"
      }
    },
    {
      "name": "JSON key",
      "scope": [
        "support.type.property-name.json",
        "meta.structure.dictionary.key.json"
      ],
      "settings": {
        "foreground": "#6EA8E8"
      }
    },
    {
      "name": "YAML key",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#6EA8E8"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#B5E81F",
    "function.declaration": "#B5E81F",
    "method": "#B5E81F",
    "method.declaration": "#B5E81F",
    "class": "#6EA8E8",
    "interface": "#6EA8E8",
    "type": "#6EA8E8",
    "typeParameter": {
      "foreground": "#6EA8E8",
      "fontStyle": "italic"
    },
    "enum": "#6EA8E8",
    "enumMember": "#C68DD0",
    "namespace": "#6EA8E8",
    "parameter": "#E4E2DA",
    "variable": "#E4E2DA",
    "variable.constant": "#C68DD0",
    "variable.readonly": "#C68DD0",
    "property": "#E4E2DA",
    "property.declaration": "#E4E2DA",
    "property.readonly": "#C68DD0",
    "macro": {
      "foreground": "#C68DD0",
      "fontStyle": "italic"
    },
    "decorator": {
      "foreground": "#C68DD0",
      "fontStyle": "italic"
    },
    "keyword": "#D4EE7A"
  }
}