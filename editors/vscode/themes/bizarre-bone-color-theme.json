  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#7A7A7A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment doc",
      "scope": [
        "comment.block.documentation"
      ],
      "settings": {
        "foreground": "#7A7A7A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable, parameter, property",
      "scope": [
        "variable",
        "support.variable",
        "meta.definition.variable",
        "variable.parameter",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#2B2B2B"
      }
    },
    {
      "name": "Variable language (this, self)",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#9558A0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "storage"
      ],
      "settings": {
        "foreground": "#6B8A0E"
      }
    },
    {
      "name": "Storage type modifier",
      "scope": [
        "storage.modifier",
        "storage.type.function",
        "keyword.operator.expression.typeof"
      ],
      "settings": {
        "foreground": "#6B8A0E",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#545454"
      }
    },
    {
      "name": "String interpolation punctuation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#6B8A0E"
      }
    },
    {
      "name": "String escape",
      "scope": [
        "constant.character.escape",
        "string.regexp",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#4A9595"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#A87330"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#9558A0"
      }
    },
    {
      "name": "Function name (the lime hero)",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function",
        "meta.definition.function entity.name.function"
      ],
      "settings": {
        "foreground": "#6B8A0E"
      }
    },
    {
      "name": "Function call (slightly less hot)",
      "scope": [
        "meta.function-call.generic",
        "variable.function"
      ],
      "settings": {
        "foreground": "#6B8A0E"
      }
    },
    {
      "name": "Class / type / interface",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.other.inherited-class",
        "support.type",
        "support.class",
        "meta.type"
      ],
      "settings": {
        "foreground": "#3068AA"
      }
    },
    {
      "name": "Operator / punctuation",
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#7A7A7A"
      }
    },
    {
      "name": "Decorator",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#9558A0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup heading",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#6B8A0E",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#3068AA",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markup bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#2B2B2B",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#2B2B2B",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#4A9595"
      }
    },
    {
      "name": "Markup quote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#7A7A7A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup list",
      "scope": [
        "markup.list",
        "punctuation.definition.list_item"
      ],
      "settings": {
        "foreground": "#6B8A0E"
      }
    },
    {
      "name": "Diff added",
      "scope": [
        "markup.inserted",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#2A8439"
      }
    },
    {
      "name": "Diff removed",
      "scope": [
        "markup.deleted",
        "meta.diff.header.from-file"
      ],
      "settings": {
        "foreground": "#C13039"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#A87330"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml",
        "punctuation.definition.tag"
