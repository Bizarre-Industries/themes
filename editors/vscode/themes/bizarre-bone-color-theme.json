      ],
      "settings": {
        "foreground": "#6B8A0E"
      }
    },
    {
      "name": "CSS pseudo",
      "scope": [
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#9558A0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#C13039",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Python self",
      "scope": [
        "variable.language.special.self.python"
      ],
      "settings": {
        "foreground": "#9558A0",
        "fontStyle": "italic"
      }
