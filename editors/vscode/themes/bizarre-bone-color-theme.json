        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#9558A0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Go package",
      "scope": [
        "entity.name.package.go"
      ],
      "settings": {
        "foreground": "#3068AA"
      }
    },
    {
      "name": "Shell command",
      "scope": [
