{
  "manifest_version": 2,
  "name": "Bizarre Void Hi-Contrast for Firefox",
  "version": "0.2.0",
  "theme": {
    "colors": {
      "frame": "#0E0E0E",
      "frame_inactive": "#000000",
      "toolbar": "#000000",
      "toolbar_text": "#F9F8F2",
      "tab_text": "#F9F8F2",
      "tab_background_text": "#B8B8B8",
      "bookmark_text": "#B8B8B8",
      "icons": "#B8B8B8",
      "icons_attention": "#C6FF24",
      "toolbar_field": "#0E0E0E",
