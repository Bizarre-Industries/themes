{
  "manifest_version": 2,
  "name": "Bizarre Workshop for Firefox",
  "version": "0.2.0",
  "theme": {
    "colors": {
      "frame": "#23211C",
      "frame_inactive": "#1A1815",
      "toolbar": "#1A1815",
      "toolbar_text": "#E4E2DA",
      "tab_text": "#E4E2DA",
      "tab_background_text": "#9C9A91",
