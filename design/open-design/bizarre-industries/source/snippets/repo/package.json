{
  "name": "bizarre-themes",
  "version": "0.2.0",
  "private": true,
  "description": "Bizarre Industries editor, terminal, shell, and tool themes.",
  "license": "MIT",
  "scripts": {
    "generate": "node scripts/generate.cjs",
    "generate:open-design": "node scripts/generate-open-design.cjs",
    "check:generated": "node scripts/check-generated.cjs",
    "check:open-design": "node scripts/generate-open-design.cjs --check",
    "test:contracts": "node --test test/*.test.cjs",
    "render:showcase": "node scripts/render-showcase.cjs",
    "render:local": "node scripts/render-local-captures.cjs",
    "check:showcase": "node scripts/render-showcase.cjs --check",
    "check:local": "node scripts/render-local-captures.cjs --check",
    "validate": "node scripts/validate.cjs",
    "validate:strict": "node scripts/validate.cjs --strict",
    "test": "npm run test:contracts && npm run check:generated && npm run check:open-design && npm run validate"
  },
  "engines": {
    "node": "^20.17.0 || >=22.9.0"
  },
  "dependencies": {
    "@babel/standalone": "7.29.0",
    "@fontsource/monaspace-argon": "5.2.5",
    "@fontsource/monaspace-krypton": "5.2.5",
    "@fontsource/monaspace-neon": "5.2.5",
    "@fontsource/monaspace-xenon": "5.2.5",
    "@iarna/toml": "^2.2.5",
    "ini": "^6.0.0",
    "playwright": "^1.52.0",
    "postcss": "^8.5.14",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "yaml": "^2.8.4"
  }
}
