  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#726D60",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Documentation",
      "scope": [
        "comment.block.documentation"
      ],
      "settings": {
        "foreground": "#597629",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "support.variable",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#1A1A1A"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#A0480E",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Properties",
      "scope": [
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#597629"
      }
    },
    {
      "name": "Self",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#B8276F",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords control",
      "scope": [
        "keyword.control",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#B8276F"
      }
    },
    {
      "name": "Keywords declaration",
      "scope": [
        "storage.type",
        "storage.modifier",
        "keyword.declaration"
      ],
      "settings": {
        "foreground": "#7E2A9A"
      }
    },
    {
      "name": "Keywords modifier",
      "scope": [
        "storage.modifier.async",
        "storage.modifier.static"
      ],
      "settings": {
        "foreground": "#603F94",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "punctuation.separator"
      ],
      "settings": {
        "foreground": "#0F6E6E"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#726D61"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#9F4A0E"
      }
    },
    {
      "name": "Templates",
      "scope": [
        "string.template",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#AD5418"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#7A6308",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#A55A1B",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#1F4FB0"
      }
    },
    {
      "name": "Booleans",
      "scope": [
        "constant.language.boolean",
        "constant.language.null"
      ],
      "settings": {
        "foreground": "#1B4099",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#2F5DC2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "support.type",
        "entity.name.class",
        "entity.name.struct"
      ],
      "settings": {
        "foreground": "#0F6E6E"
      }
    },
    {
      "name": "Primitive types",
      "scope": [
        "support.type.primitive"
      ],
      "settings": {
        "foreground": "#0F6E6E",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#4A7409"
      }
    },
    {
      "name": "Methods",
      "scope": [
        "entity.name.function.member",
        "support.function.method"
      ],
      "settings": {
        "foreground": "#4A7409"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.constant",
        "support.class",
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#9F4A0E"
      }
    },
    {
      "name": "Namespaces",
      "scope": [
        "entity.name.namespace",
        "support.module"
      ],
      "settings": {
        "foreground": "#0F6E6E"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#B8276F",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Preprocessor",
      "scope": [
        "meta.preprocessor",
        "keyword.control.directive"
      ],
      "settings": {
        "foreground": "#603F94"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#B8276F"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#4A7409"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#AC2468",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup heading",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#4A7409",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup link",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#1F4FB0",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markup bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#1A1A1A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#1A1A1A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#36691B"
      }
    },
    {
      "name": "Diff deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#AC2468"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#97460D"
      }
    }
  ],
  "semanticTokenColors": {
    "variable": "#1A1A1A",
    "parameter": {
      "foreground": "#A0480E",
      "italic": true
    },
    "property": "#597629",
    "function": "#4A7409",
    "method": "#4A7409",
    "class": "#0F6E6E",
    "struct": "#0F6E6E",
    "interface": "#0F6E6E",
    "enum": "#0F6E6E",
    "enumMember": "#2F5DC2",
    "type": "#0F6E6E",
    "typeParameter": {
      "foreground": "#0F6E6E",
      "italic": true
    },
    "namespace": "#0F6E6E",
    "keyword": "#B8276F",
    "string": "#9F4A0E",
    "number": "#1F4FB0",
    "regexp": {
      "foreground": "#A55A1B",
      "italic": true
    },
    "decorator": {
      "foreground": "#B8276F",
      "italic": true
    },
    "comment": {
      "foreground": "#726D60",
      "italic": true
    }
  },
  "$schema": "vscode://schemas/color-theme"
}
