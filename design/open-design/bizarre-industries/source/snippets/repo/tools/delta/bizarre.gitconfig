# Bizarre Industries - delta themes
# Add to ~/.gitconfig:
#   [include]
#       path = /path/to/themes/tools/delta/bizarre.gitconfig
#   [delta]
#       features = bizarre-void

[delta "bizarre-void"]
    dark = true
    line-numbers = true
    navigate = true
    hyperlinks = true
    commit-decoration-style = box ul #C6FF24
    file-style = bold #C6FF24
    file-decoration-style = ul #3D3D3D
    hunk-header-style = file line-number syntax bold
    hunk-header-decoration-style = #3D3D3D
    minus-style = syntax #1A1A1A
    minus-emph-style = bold syntax #FF6F77
    plus-style = syntax #1A1A1A
    plus-emph-style = bold syntax #5BD06B
    zero-style = syntax
    line-numbers-left-style = #9C9C9C
    line-numbers-right-style = #9C9C9C
    line-numbers-minus-style = #FF6F77
    line-numbers-plus-style = #5BD06B

[delta "bizarre-void-hicontrast"]
    dark = true
    line-numbers = true
    navigate = true
    hyperlinks = true
    commit-decoration-style = box ul #C6FF24
    file-style = bold #C6FF24
    file-decoration-style = ul #545454
    hunk-header-style = file line-number syntax bold
    hunk-header-decoration-style = #545454
    minus-style = syntax #0E0E0E
    minus-emph-style = bold syntax #FF6F77
    plus-style = syntax #0E0E0E
    plus-emph-style = bold syntax #5BD06B
    zero-style = syntax
    line-numbers-left-style = #B8B8B8
    line-numbers-right-style = #B8B8B8
    line-numbers-minus-style = #FF6F77
    line-numbers-plus-style = #5BD06B

