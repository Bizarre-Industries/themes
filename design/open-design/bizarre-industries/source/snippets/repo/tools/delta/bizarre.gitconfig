    hunk-header-style = file line-number syntax bold
    hunk-header-decoration-style = #D8D4C7
    minus-style = syntax #F2F0EA
    minus-emph-style = bold syntax #AC2468
    plus-style = syntax #F2F0EA
    plus-emph-style = bold syntax #36691B
    zero-style = syntax
    line-numbers-left-style = #3D3D3D
    line-numbers-right-style = #3D3D3D
    line-numbers-minus-style = #AC2468
    line-numbers-plus-style = #36691B

