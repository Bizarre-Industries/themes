{
  "$schema": "https://binarynights.com/schemas/forklift-theme-v4.json",
  "name": "Bizarre",
  "author": "Bizarre Industries",
  "version": "0.2",
  "description": "CATCH THE STARS. Signal Lime accent on Void backgrounds.",
  "appearance": "dark",
  "background": "#0E0E0E",
