{
  "manifest_version": 2,
  "name": "Bizarre Paper for Firefox",
  "version": "0.2.0",
  "theme": {
    "colors": {
      "frame": "#F2F0EA",
      "frame_inactive": "#F9F8F2",
      "toolbar": "#F9F8F2",
      "toolbar_text": "#1F1F1F",
      "tab_text": "#1F1F1F",
      "tab_background_text": "#3D3D3D",
      "bookmark_text": "#3D3D3D",
      "icons": "#3D3D3D",
      "icons_attention": "#5F8A0F",
      "toolbar_field": "#F2F0EA",
      "toolbar_field_text": "#1F1F1F",
      "toolbar_field_border": "#D8D4C7",
      "button_background_active": "#DCEFA8",
